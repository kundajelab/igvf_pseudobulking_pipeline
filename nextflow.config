manifest {
    contributors = [
        [name: 'Salil Deshpande', email: 'salil512@stanford.edu'],
        [name: 'Ted Brookings', email: 'tedbrookings@stanford.edu'],
    ]
    homePage = 'https://github.com/kundajelab/igvf_pseudobulking_pipeline'
    description = 'Workflow for downloading and pseudobulking IGVF processed data'
    mainScript = 'main.nf'
    version = '0.2.0'
    nextflowVersion = '>=25.4.6' // DSL2 is the default starting here
}

plugins {
    id 'nf-schema@2.4.2'
    id 'nf-dotenv@1.0.0'
}

resume = true

params {
    // TSV with metadata for performing pseudobulking, with columns "analysis_accession", "barcode"
    // "subsample", "subsample_orig", and "annotation". Must be supplied.
    metadata_file
    // comma-separeted list of principal analyses to associate results with for IGVF upload. Inferred if not supplied.
    principal_analysis
    // IGVF mode for upload. Can be "prod", "staging", or "sandbox". Default is "prod".
    igvf_mode = "prod"
    // If true, do not actually upload to IGVF, the upload script just checks for schema compliance.
    igvf_dry_run = true
    // comma-separated list of accessions to process. If null, process all accessions in the metadata file.
    accessions = null
    // Species to process (e.g. "human" or "mouse")
    species = "human"
    // Number of "top" peaks to keep
    num_top_peaks = 300000
    // Minimum overlap for peaks in bedtools intersect
    min_overlap = 0.5
    // IGVF url for downloading metadata for accessions
    igvf_metadata_url = "https://api.data.igvf.org/analysis-sets"
    igvf_fragments_url = "https://api.data.igvf.org/tabular-files"
    igvf_counts_matrix_url = "https://api.data.igvf.org/matrix-files"
    // folder to store all pipeline temporary files and outputs
    workspace = "workspace"
    // publishDir mode for outputs
    publish_mode = "symlink"
    // How many CPUS should SPLIT_FRAGMENTS jobs use? In a local executor, there is a lot of
    // contention for file IO, so 6 is max throughput.
    split_fragments_cpus = 6
    // Should SPLIT_FRAGMENTS jobs run in parallel?contend with one another for resources?
    // If true, run sequentially because it will actually be slower to run in parallel.
    // If false, run in parallel.
    // If null, automatically decide based on profile. Typically on the cluster they will not have
    // contention, but locally they may be starved for IO.
    split_fragments_parallel = null
    // queue for running slurm jobs
    slurm_queue = "normal"
    // slurm jobs may be preempted, so allow more retries there than locally
    preemptible_max_retries = 5
    // only retry due to out-of-memory errors this many times
    oom_max_retries = 2
}

workDir = "${params.workspace}/${params.principal_analysis.replace(",", "-")}/work"
outputDir = "${params.workspace}/${params.principal_analysis.replace(",", "-")}/output/"

process {
    // stop on errors, log commands
    shell = ['/bin/bash', '-euxo', 'pipefail']
    // tasks that need to retry will override this:
    maxRetries = 0
}

profiles {
    arm {
        // docker.runOptions = '-u $(id -u):$(id -g) --platform=linux/amd64'
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    local {
        process.executor = 'local'
        params.split_fragments_parallel = params.split_fragments_parallel == null ? false : params.split_fragments_parallel
        process {
            executor = "local"
            // if something is likely out of memory and has more than 0 retries: retry
            // otherwise terminate
            errorStrategy = {
                task.maxRetries > 0 && task.exitStatus in 130..145 ?
                'retry' :
                'terminate'
            }
            // tasks that need to retry will override this:
            maxRetries = 0
        }
    }
    slurm {
        process {
            executor = 'slurm'
            queue = params.slurm_queue
            clusterOptions = "--export=ALL "
            // owners queue jobs get preempted (signalled with exit status 15); retry
            // those the same as obvious out-of-memory errors
            errorStrategy = params.slurm_queue == "owners" ? {
                task.exitStatus in 130..145 || task.exitStatus == 15 ?
                'retry' :
                'terminate'
            } : {
                task.maxRetries > 0 && task.exitStatus in 130..145 ?
                'retry' :
                'terminate'
            }
            // tasks that need OOM-based retries will override this:
            maxRetries = params.slurm_queue == "owners" ? params.preemptible_max_retries : 0
        }
        params.split_fragments_parallel = params.split_fragments_parallel == null ? true : params.split_fragments_parallel
    }
    conda {
        conda.enabled = true
    }
    docker {
        docker.enabled = true
    }
    apptainer {
        apptainer.enabled = true
    }
}

conda {
    cacheDir = "${params.workspace}/conda_cache"
    useMicromamba = true
    createTimeout = '1 h'
}

apptainer {
    autoMounts = true
    cacheDir = "${params.workspace}/apptainer_cache"
}

def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    overwrite = true
    file    = "${params.workspace}/${params.principal_analysis.replace(",", "-")}/trace/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    overwrite = true
    file    = "${params.workspace}/${params.principal_analysis.replace(",", "-")}/trace/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    overwrite = true
    file    = "${params.workspace}/${params.principal_analysis.replace(",", "-")}/trace/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    overwrite = true
    file    = "${params.workspace}/${params.principal_analysis.replace(",", "-")}/trace/pipeline_dag_${trace_timestamp}.html"
}
